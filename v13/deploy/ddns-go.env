# ddns-go 远程访问配置
# ----------------------------------------------------------------------------
# ddns-go 通过 HTTPS 反向代理暴露 quant-api-node / quant-ui-node
# 部署：docker run -d --name ddns-go -p 9876:9876 \
#            -v /var/lib/ddns-go:/root jeessy/ddns-go
# 然后访问 http://nas-ip:9876 完成域名绑定
# ----------------------------------------------------------------------------

# === DNS 提供商选择（Cloudflare 为推荐） ===
# DDNSGO_DNS=cloudflare
# DDNSGO_CLOUDFLARE_TOKEN=<your-api-token>
# DDNSGO_CLOUDFLARE_ZONE=your-domain.com

# === 阿里云 DNS（备选，国内访问优化） ===
# DDNSGO_DNS=alidns
# DDNSGO_ALIDNS_AK=<your-access-key>
# DDNSGO_ALIDNS_SK=<your-secret-key>

# === 域名记录 ===
# 主机记录：quant.tailrisk   →   记录类型：A   →   记录值：自动检测公网 IP

# === HTTPS 反代配置（ddns-go 内置 Caddy） ===
# 自动申请 Let's Encrypt 证书（需域名已解析到公网 IP）

# === 反代目标（与 docker-compose.yml 端口对齐） ===
# - quant.tailrisk → http://nas-ip:80    （Nginx 入口）
#   Nginx 已内部转发：
#     /api/*  →  quant-api-node:8080
#     /ws/*   →  quant-api-node:8080 (WebSocket Upgrade)
#     /       →  quant-ui-node:3000

# === 健康检查（远程监控） ===
# 建议配置 UptimeRobot / 阿里云监控：
#   https://quant.tailrisk/api/health     → 期望 200 + {"ok": true, ...}
#   https://quant.tailrisk/                → 期望 200 + HTML

# === 远程安全加固（可选） ===
# 1. Nginx basic auth:
#    auth_basic "V1.3 Console";
#    auth_basic_user_file /etc/nginx/.htpasswd;
# 2. fail2ban 拦截暴力破解
# 3. 仅允许中国大陆/美国 IP 段访问（geoip 模块）