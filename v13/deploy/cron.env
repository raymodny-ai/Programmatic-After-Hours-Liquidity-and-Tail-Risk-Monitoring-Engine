# V13 docker-compose 环境变量模板
# ----------------------------------------------------------------------------
# 复制为 .env 并填入实际值：
#   cp cron.env .env
# ----------------------------------------------------------------------------

# Polygon.io
POLYGON_API_KEY=

# FRED
FRED_API_KEY=

# ThetaData 本地代理（默认指向宿主网关）
THETADATA_PROXY_URL=http://host.docker.internal:25510

# FINRA Margin Debt 抓取（可选）
FINRA_DOWNLOAD_URL=https://www.finra.org/sites/default/files/2021-03/margin-statistics
