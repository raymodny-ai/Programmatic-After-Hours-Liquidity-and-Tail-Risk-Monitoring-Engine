# =============================================================================
# 程序化盘后流动性与尾部风险监控引擎 - 环境变量配置模板
# 复制此文件为 .env 并填入实际的 API 密钥
# =============================================================================

# --- Polygon.io API ---
# 用于获取 SPY/QQQ/IWM/DIA 的日终期权链数据
# 免费层限制: 5次/分钟
# 注册地址: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# --- FRED API ---
# 用于获取 M2 货币供应量数据 (系列: M2SL)
# 注册地址: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# --- Google Sheets API ---
# Service Account JSON 凭证文件的本地路径
# 需要在 Google Cloud Console 中创建 Service Account 并启用 Google Sheets API
# 参考: https://docs.gspread.org/en/latest/oauth2.html
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google_service_account.json

# Google Sheets 看板 ID (从 Google Sheets URL 中提取)
# 格式: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# --- VIX Central / Cboe ---
# VIX Central 目前无需 API Key，通过公开 URL 获取
# 如果使用 Cboe 数据，在此处配置相关参数
VIX_DATA_SOURCE=vix_central

# --- 日志配置 ---
LOG_LEVEL=INFO
LOG_DIR=logs/

# --- 速率限制配置 ---
# Polygon.io 免费层: 5次/分钟，建议保守设置为4次/分钟
RATE_LIMIT_CALLS_PER_MINUTE=4
# 最大重试次数
MAX_RETRIES=5
# 初始退避等待时间（秒）
RETRY_BACKOFF_INITIAL=2
